{
  "name": "data-drift",
  "displayName": "Data Drift",
  "description": "Launch Data Drift instantly for quick focus breaks",
  "version": "1.0.0",
  "publisher": "reginald-erzoah",

  "repository": {
    "type": "git",
    "url": "https://github.com/ReginaldErzoah/data-drift"
  },

  "keywords": [
    "game",
    "focus",
    "productivity",
    "break",
    "pomodoro",
    "entertainment",
    "data drift"
  ],

  "engines": {
    "vscode": "^1.85.0"
  },

  "categories": ["Other"],

  "activationEvents": [
    "onView:datadriftView",
    "onCommand:data-drift.launch"
  ],

  "main": "./extension.js",

  "contributes": {
    "commands": [
      {
        "command": "data-drift.launch",
        "title": "Play Data Drift"
      }
    ],

    "viewsContainers": {
      "activitybar": [
        {
          "id": "datadrift",
          "title": "Data Drift",
          "icon": "icons/icon.svg"
        }
      ]
    },

    "views": {
      "datadrift": [
        {
          "id": "datadriftView",
          "name": "Quick Break",
          "icon": "icons/icon.svg"
        }
      ]
    }
  }
}