{
  "name": "data-drift",
  "displayName": "Data Drift",
  "description": "Launch Data Drift instantly for quick focus breaks",
  "version": "1.0.0",
  "publisher": "reginald-erzoah",

  "engines": {
    "vscode": "^1.85.0"
  },

  "categories": ["Other"],

  "activationEvents": ["*"],

  "main": "./extension.js",

  "contributes": {
    "commands": [
      {
        "command": "data-drift.launch",
        "title": "Play Data Drift"
      }
    ],

    "viewsContainers": {
      "activitybar": [
        {
          "id": "datadrift",
          "title": "Data Drift",
          "icon": "icons/icon.png"
        }
      ]
    },

    "views": {
      "datadrift": [
        {
          "id": "datadriftView",
          "name": "Quick Break"
        }
      ]
    }
  }
}